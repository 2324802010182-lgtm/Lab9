@page
@model LoginModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Log in";
}

<div class="container">
    <div class="row">
        <div class="col s12 m5 offset-m2">
            <form asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="Input.Email" type="email" class="validate" />
                        <label asp-for="Input.Email">Email</label>
                        <span class="helper-text" data-error="wrong" data-success="right"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="Input.Password" type="password" class="validate" />
                        <label asp-for="Input.Password">Password</label>
                        <span class="helper-text" data-error="wrong" data-success="right"></span>
                    </div>
                </div>

                <div class="row padding-left-10px">
                    <p>
                        <label>
                            <input asp-for="Input.RememberMe" type="checkbox" class="filled-in" />
                            <span asp-for="Input.RememberMe">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </span>
                        </label>
                    </p>
                </div>

                <div class="row center">
                    <button class="btn waves-effect waves-light" type="submit">
                        Submit
                        <i class="material-icons right">send</i>
                    </button>
                </div>

                <div class="row center">
                    <a href="/Identity/Account/ForgotPassword">Forgot your password?</a>
                </div>
            </form>

            <div class="col s12 m12">
                <h6>Using External Providers</h6>
                <div class="divider"></div>

                @{
                    var loginProviders = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();

                    if (loginProviders.Count == 0)
                    {
                        <div class="row">
                            <div class="col s12">
                                <p>No external login providers configured.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <form asp-area="Identity"
                              asp-page="/Account/ExternalLogin"
                              asp-route-returnUrl="@ViewData["ReturnUrl"]"
                              method="post"
                              class="form-horizontal">

                            <div class="row center" style="margin-top: 20px;">
                                @foreach (var provider in loginProviders)
                                {
                                    <button type="submit"
                                            class="btn red darken-1 waves-effect waves-light"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account"
                                            style="margin: 5px;">
                                        @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>