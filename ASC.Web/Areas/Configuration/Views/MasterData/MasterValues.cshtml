@using ASC.Model.Models
@using ASC.Web.Areas.Configuration.Models
@model MasterValuesViewModel
@{
    Layout = "_SecureLayout";
    var masterKeyList = ViewBag.MasterKeys as IEnumerable<MasterDataKey> ?? Array.Empty<MasterDataKey>();
}

<div class="row padding-top-20px padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="section white-text padding-left-10px blue-grey lighten-1">
            <h5>Master Values</h5>
        </div>
        <div class="divider"></div>

        <div class="row margin-bottom-0 padding-left-10px padding-right-10px">
            <div class="input-field col s12 m6 l4">
                <select id="ddlMasterKeys">
                    <option value="" disabled selected>-- Select --</option>
                    @foreach (var k in masterKeyList)
                    {
                        <option value="@k.PartitionKey">@k.PartitionKey</option>
                    }
                </select>
                <label class="active">Partition Key</label>
            </div>
            <div class="col s12 m6 l8 padding-bottom-15px right-align valign-wrapper" style="min-height: 64px; justify-content: flex-end;">
                <a class="modal-trigger waves-effect waves-light btn-floating blue-grey lighten-1"
                   href="#modal1" title="Upload Excel">
                    <i class="material-icons">cloud_upload</i>
                </a>
            </div>
        </div>

        <div class="col s12 padding-bottom-15px">
            <table class="highlight centered" id="tblMasterValues">
                <thead>
                    <tr>
                        <th>Row Key</th>
                        <th>Partition Key</th>
                        <th>Name</th>
                        <th>Is Active</th>
                        <th>Edit</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div class="row"></div>

    <div class="row z-depth-3">
        <div class="col s12 padding-0px">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>Master Value Details</h5>
            </div>
            <div class="divider"></div>

            <form asp-area="Configuration" asp-controller="MasterData" asp-action="MasterValues" method="post" class="col s12" id="formMasterValue">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IsEdit" />

                <div class="row padding-left-10px padding-right-10px">
                    <div class="input-field col s12 m4">
                        <input asp-for="MasterValueInContext.RowKey" id="Input_MasterValue_RowKey" readonly autocomplete="off" class="grey-text text-darken-1" />
                        <label asp-for="MasterValueInContext.RowKey" class="active"></label>
                    </div>

                    <div class="input-field col s12 m4">
                        <select id="Select_MasterValueInContext_PartitionKey" required>
                            <option value="" disabled selected>-- Select --</option>
                            @foreach (var k in masterKeyList)
                            {
                                <option value="@k.PartitionKey">@k.PartitionKey</option>
                            }
                        </select>
                        <label class="active">Partition Key</label>
                    </div>

                    <div class="input-field col s12 m4">
                        <input asp-for="MasterValueInContext.Name" id="MasterValueInContext_Name" class="validate" autocomplete="off" />
                        <label asp-for="MasterValueInContext.Name"></label>
                    </div>
                </div>

                <div class="row padding-left-10px padding-right-10px">
                    <div class="input-field col s12 m4">
                        <div class="switch">
                            <label>
                                Is Active
                                <input asp-for="MasterValueInContext.IsActive" type="checkbox" />
                                <span class="lever"></span>
                            </label>
                        </div>
                    </div>

                    <div class="input-field col s12 m8 right-align">
                        <button class="btn waves-effect waves-light btnSubmit" type="button" name="action">
                            Create
                            <i class="material-icons right">send</i>
                        </button>

                        <button class="btn waves-effect waves-light reset red lighten-1" type="button" name="action">
                            Reset
                        </button>
                    </div>

                    <div class="row col s12 right-align" asp-validation-summary="All"></div>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="modal1" class="modal modal-fixed-footer">
    <div class="modal-content">
        <h4>Upload Excel</h4>
        <p>Upload the Excel file that contains all the master values.</p>

        <div class="row hide divErrors">
            <div class="col s12">
                <div class="card-panel red lighten-1">
                    <span class="white-text errors"></span>
                </div>
            </div>
        </div>

        <div class="progress hide">
            <div class="indeterminate"></div>
        </div>

        <div class="file-field input-field">
            <div class="btn">
                <span>File</span>
                <input type="file" id="files" accept=".xlsx,.xls">
            </div>
            <div class="file-path-wrapper">
                <input class="file-path validate" type="text" readonly>
            </div>
        </div>
        <div class="input-field row right">
            <button class="btn waves-effect waves-light btnUpload" type="button" name="action">
                Upload
                <i class="material-icons right">send</i>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("~/Views/Shared/_ValidationScriptsPartial.cshtml")
    <script src="/lib/jquery/dist/jquery.js"></script>
    <script>
        // Ensure $ is available for page scripts (some layouts may fail to load jQuery).
        window.$ = window.$ || window.jQuery;
    </script>
    <script>
        $(document).ready(function () {
            var token = $('#formMasterValue').find('input[name="__RequestVerificationToken"]').val()
                || $('input[name="__RequestVerificationToken"]').first().val();
            $.ajaxSetup({
                cache: false,
                headers: { 'RequestVerificationToken': token }
            });

            var table = $('#tblMasterValues').DataTable({
                ajax: {
                    url: '@Url.Action("MasterValuesByKey", "MasterData", new { area = "Configuration" })',
                    type: 'GET',
                    data: function () {
                        return { key: $('#ddlMasterKeys').val() || '' };
                    },
                    dataSrc: 'data'
                },
                pageLength: 3,
                lengthMenu: [[3, 5, 10, -1], [3, 5, 10, 'All']],
                columns: [
                    { data: 'RowKey' },
                    { data: 'PartitionKey' },
                    { data: 'Name' },
                    {
                        data: 'IsActive',
                        render: function (data) {
                            if (data === true || data === 'True')
                                return '<img src="/images/green_tick.png" alt="" />';
                            return '<img src="/images/red_cross.png" alt="" />';
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        defaultContent: '<i class="small material-icons edit cursor-hand">mode_edit</i>'
                    }
                ]
            });

            $('#tblMasterValues').css('width', '100%');

            function initSelects() {
                if (!window.M) return;
                $('#ddlMasterKeys').formSelect();
                $('#Select_MasterValueInContext_PartitionKey').formSelect();
                $('select[name="tblMasterValues_length"]').formSelect();
                M.updateTextFields();
            }

            // Init selects after first paint
            setTimeout(initSelects, 0);

            $('#tblMasterValues').on('length.dt', function () {
                $('select[name="tblMasterValues_length"]').formSelect();
            });

            function newGuid() {
                // RFC4122 v4 style, good enough for UI preview
                return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
                    var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
                    return v.toString(16);
                });
            }

            function ensureGeneratedFields() {
                if ($('#IsEdit').val() === 'True') return;
                if (!($('#Input_MasterValue_RowKey').val() || '').trim()) {
                    $('#Input_MasterValue_RowKey').val(newGuid());
                    $('#MasterValueInContext_RowKey').val($('#Input_MasterValue_RowKey').val());
                }
                M.updateTextFields();
            }

            $(document).on('change', '#Select_MasterValueInContext_PartitionKey', ensureGeneratedFields);
            $(document).on('input', '#MasterValueInContext_Name', ensureGeneratedFields);

            $(document).on('click', '.reset', function () {
                // reset select cleanly
                if (window.M) {
                    var detail = $('#Select_MasterValueInContext_PartitionKey');
                    if (detail.length) {
                        var inst = M.FormSelect.getInstance(detail[0]);
                        if (inst) inst.destroy();
                    }
                }

                $('#formMasterValue')[0].reset();
                $('#IsEdit').val('False');
                $('.btnSubmit').text('Create');
                $('#Input_MasterValue_RowKey').val('');
                $('#Select_MasterValueInContext_PartitionKey').prop('disabled', false);
                setTimeout(initSelects, 0);
            });

            $(document).on('click', '#tblMasterValues tbody', function (e) {
                var $icon = $(e.target).closest('.edit');
                if (!$icon.length) return;

                var user = table.row($icon.closest('tr')).data();
                if (!user) return;

                $('#IsEdit').val('True');

                $('#MasterValueInContext_RowKey').val(user.RowKey);
                $('#Input_MasterValue_RowKey').val(user.RowKey);

                $('#Select_MasterValueInContext_PartitionKey').val(user.PartitionKey);
                $('#Select_MasterValueInContext_PartitionKey').prop('disabled', true);
                if (window.M) {
                    var detail = $('#Select_MasterValueInContext_PartitionKey');
                    var inst = M.FormSelect.getInstance(detail[0]);
                    if (inst) inst.destroy();
                    setTimeout(initSelects, 0);
                }

                $('#MasterValueInContext_Name').val(user.Name);
                $('#MasterValueInContext_Name').addClass('valid');

                var active = user.IsActive === true || user.IsActive === 'True';
                $('#MasterValueInContext_IsActive').prop('checked', active);

                $('.btnSubmit').text('Save');
                M.updateTextFields();
            });

            $(document).on('change', '#ddlMasterKeys', function () {
                table.ajax.reload();
            });

            $(document).on('click', '.btnSubmit', function () {
                var name = ($('#MasterValueInContext_Name').val() || '').trim();
                var pk = $('#Select_MasterValueInContext_PartitionKey').val();
                if (!name) {
                    M.toast({ html: 'Please enter a name.' });
                    return;
                }
                if (!pk) {
                    M.toast({ html: 'Please select a partition key.' });
                    return;
                }

                var masterData = {
                    Name: name,
                    PartitionKey: pk,
                    IsActive: $('#MasterValueInContext_IsActive').is(':checked'),
                    RowKey: $('#Input_MasterValue_RowKey').val()
                };
                if ($('#IsEdit').val() === 'True') {
                    masterData.RowKey = $('#MasterValueInContext_RowKey').val();
                }

                $.post('@Url.Action("MasterValues", "MasterData", new { area = "Configuration" })',
                    { masterValue: masterData, isEdit: $('#IsEdit').val() },
                    function (data) {
                        if (data === true || data === 'True') {
                            table.ajax.reload();
                            $('.reset').trigger('click');
                            $('.select-wrapper').removeClass('valid');
                        } else {
                            M.toast({ html: 'Could not save. Check validation / anti-forgery.' });
                        }
                    }
                ).fail(function () {
                    M.toast({ html: 'Request failed.' });
                });
            });

            $('.modal').modal();

            $(document).on('click', '.btnUpload', function () {
                var fileUpload = $('#files').get(0);
                if (!fileUpload || !fileUpload.files || !fileUpload.files.length) {
                    M.toast({ html: 'Please choose a file.' });
                    return;
                }

                var data = new FormData();
                data.append('__RequestVerificationToken', token);
                data.append(fileUpload.files[0].name, fileUpload.files[0]);

                $('.progress').removeClass('hide');
                $('.divErrors').addClass('hide');

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("UploadExcel", "MasterData", new { area = "Configuration" })',
                    contentType: false,
                    processData: false,
                    data: data,
                    success: function (message) {
                        $('.progress').addClass('hide');
                        if (message.Success) {
                            window.location.reload();
                        }
                        if (message.Error) {
                            $('.divErrors').removeClass('hide');
                            $('.errors').html(message.Text);
                        }
                    },
                    error: function () {
                        $('.progress').addClass('hide');
                        M.toast({ html: 'Upload failed.' });
                    }
                });
            });
        });
    </script>
}
